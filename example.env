# LightNode environment example
# Copy this to .env or load it in your shell before starting the app.

# Storage location must point to a prepared LightNode storage drive.
# Windows example:
# LIGHTNODE_STORAGE_ROOT=C:\lightnode\storage
# Linux example:
# LIGHTNODE_STORAGE_ROOT=/srv/lightnode/storage
LIGHTNODE_STORAGE_ROOT=C:\lightnode\storage

# Optional overrides
LIGHTNODE_INSTANCE_ID=
LIGHTNODE_MIN_FREE_BYTES=5368709120
LIGHTNODE_ALLOW_STORAGE_BOOTSTRAP=false
LIGHTNODE_REQUIRE_EXTERNAL_STORAGE=true
LIGHTNODE_STORAGE_MODE=external-drive
LIGHTNODE_MARKER_FILENAME=.lightnode
LIGHTNODE_DATABASE_FILENAME=lightnode.db
LIGHTNODE_FILES_DIRECTORY=files
LIGHTNODE_BACKUPS_DIRECTORY=backups
LIGHTNODE_VERSION=0.1.0
LIGHTNODE_MARKER_FORMAT_VERSION=1

# Optional CORS configuration for browser-based clients.
# Leave LIGHTNODE_CORS_ALLOW_ORIGINS unset to disable CORS entirely.
# Example:
# LIGHTNODE_CORS_ALLOW_ORIGINS=http://localhost:3000,https://app.example.com
LIGHTNODE_CORS_ALLOW_ORIGINS=
LIGHTNODE_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
LIGHTNODE_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-Id,X-Extension-Id
LIGHTNODE_CORS_EXPOSE_HEADERS=
LIGHTNODE_CORS_ALLOW_CREDENTIALS=false
LIGHTNODE_CORS_MAX_AGE=600
